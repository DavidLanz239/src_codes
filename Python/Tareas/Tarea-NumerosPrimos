# DESCRIPCIÓN: Programa para clasificar números como primos, compuestos o 
# perfectos (siempre que n sea menor que m).
# =============================================================================

# 1 - Declaración de variables
# Inicializamos las variables que vamos a usar en el programa
import os


n = 0                   # Límite inferior del rango
m = 0                   # Límite superior del rango
lista_primos = []       # Almacena los números primos encontrados
lista_compuestos = []   # Almacena los números compuestos encontrados
lista_perfectos = []    # Almacena los números perfectos encontrados
salida_final = []       # Lista para almacenar las líneas que irán a pantalla y archivo


# 2 - Entrada de datos
# Le pedimos al usuario que ingrese el rango de numeros asegurando que n < m
print("Recuerde que el valor de n debe ser menor que el valor de m.")
while True:
    try:
        n = int(input("Ingrese el primer número (n): "))
        m = int(input("Ingrese el segundo número (m): "))
        
        if n < m:
            break
        else:
            print("Error: El primer número debe ser menor que el segundo. Intente de nuevo.")
    except ValueError:
        print("Por favor, ingrese solo números enteros positivos.")

# 3 - Procesamiento (Identificación de números)
# Recorremos el rango cerrado [n, m]
for num in range(n, m + 1):
    
    # Lógica para Primos: Exactamente 2 divisores (1 y sí mismo) 
    # 1 no es primo [cite: 14]
    if num > 1:
        divisores = 0
        for i in range(1, num + 1):
            if num % i == 0:
                divisores += 1
        
        if divisores == 2:
            lista_primos.append(num)
        
        # Lógica para Compuestos: Más de 2 divisores 
        # Si tiene más de 2 divisores, es compuesto
        elif divisores > 2:
            lista_compuestos.append(num)
            
    # Lógica para Perfectos: Suma de divisores propios == número 
    # 1 no es perfecto [cite: 23]
    if num > 1:
        suma_propios = 0
        for i in range(1, num):
            if num % i == 0:
                suma_propios += i
        
        if suma_propios == num:
            lista_perfectos.append(num)

# 4 - Salida de datos (Terminal y memoria)
# Construimos la salida que se imprimirá y guardará
if lista_primos:
    salida_final.append("Los numeros primos encontrados son:")
    for p in lista_primos:
        salida_final.append(str(p))

if lista_compuestos:
    salida_final.append("Los numeros compuestos encontrados son:")
    for c in lista_compuestos:
        salida_final.append(str(c))

if lista_perfectos:
    salida_final.append("Los numeros perfectos encontrados son:")
    for f in lista_perfectos:
        salida_final.append(str(f))

# 4.1 - Salida en terminal
for linea in salida_final:
    print(linea)

# 5 - Salida de datos (Archivo .txt)
# Configuración de la ruta para guardar el archivo numeros.txt
directorio_destino = r"C:\Users\Admin\Documents\Developments Code\output_files"
nombre_archivo = "numeros.txt"
ruta_completa = os.path.join(directorio_destino, nombre_archivo)

os.makedirs(directorio_destino, exist_ok=True)

# Se genera el archivo numeros.txt con el contenido acumulado 
try:
    with open(ruta_completa, "w") as archivo:
        for linea in salida_final:
            archivo.write(linea + "\n")
except IOError as e:
    print(f"Error al escribir el archivo: {e}")

    
# 6 - Fin del programa